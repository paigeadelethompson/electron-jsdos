{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
  },
  "include": [
    "main.ts",
    "renderer.ts",
    "preload.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
